{
  "name": "@jeliasson/husky-hooks",
  "version": "2.0.0",
  "license": "MIT",
  "description": "Increase the developer experience and consistency by providing a set of hooks that can be opted-in the development lifecycle.",
  "author": "jeliasson",
  "homepage": "https://github.com/jeliasson/npm-husky-hooks",
  "keywords": [
    "husky",
    "hooks"
  ],
  "bugs": {
    "url": "https://github.com/jeliasson/npm-husky-hooks/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeliasson/npm-husky-hooks.git"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.16.0",
    "npm": ">=10.8.2"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "husky-hooks.config.default.cjs"
  ],
  "bin": {
    "husky-hooks": "lib/bin.js"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint --fix .",
    "test": "jest --config jestconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint"
  }
}
